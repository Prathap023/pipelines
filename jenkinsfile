pipeline {
    agent any

    stages {
        stage('Prepare') {
            steps {
                dir('PlantHierarchy/src') { 
                    echo 'Moved into the project folder...'
                    
                    // Compile Step
                    echo 'Compiling...'
                    sh 'javac PlantHierarchy.java' 
                    
                    // Execution Step
                    echo 'Executing...'
                    sh 'java PlantHierarchy'
                }
            }
        }
    }
}
